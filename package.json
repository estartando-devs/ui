{
  "name": "@estartando/monorepo",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev:docs": "bun run --filter @estartando/docs dev",
    "dev:storybook": "bun run --filter @estartando/storybook storybook",
    "build:storybook": "bun run --filter @estartando/storybook build-storybook",
    "lint": "bun run --filter '*' lint",
    "publish:ui": "cd packages/ui && bun publish --access public",
    "publish:ui:dry": "cd packages/ui && bun publish --access public --dry-run",
    "version:patch": "cd packages/ui && npm version patch --no-workspaces",
    "version:minor": "cd packages/ui && npm version minor --no-workspaces",
    "version:major": "cd packages/ui && npm version major --no-workspaces",
    "release": "bun run scripts/release.js"
  }
}
